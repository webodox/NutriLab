<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txtSymptomTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Symptoms"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <Button
        android:id="@+id/btnHeadache"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Headache"
        app:layout_constraintTop_toBottomOf="@id/txtSymptomTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <Button
        android:id="@+id/btnFatigue"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Fatigue"
        app:layout_constraintTop_toBottomOf="@id/btnHeadache"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnNausea"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Nausea"
        app:layout_constraintTop_toBottomOf="@id/btnFatigue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnSubmitSymptoms"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Submit"
        app:layout_constraintTop_toBottomOf="@id/btnNausea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FF6750A4"
        android:orientation="horizontal"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/homebutton"
            android:layout_width="218dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            app:srcCompat="@drawable/home_svgrepo_com"
            app:tint="#CBF8F4F4" />

        <ImageView
            android:id="@+id/profilebutton"
            android:layout_width="208dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            app:srcCompat="@drawable/profile_round_1342_svgrepo_com"
            app:tint="#CBF8F4F4" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>