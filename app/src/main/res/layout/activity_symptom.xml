<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txtSymptomTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Symptoms"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <Button
        android:id="@+id/btnHeadache"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Headache"
        app:layout_constraintTop_toBottomOf="@id/txtSymptomTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <Button
        android:id="@+id/btnFatigue"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Fatigue"
        app:layout_constraintTop_toBottomOf="@id/btnHeadache"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnNausea"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Nausea"
        app:layout_constraintTop_toBottomOf="@id/btnFatigue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnSubmitSymptoms"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Submit"
        app:layout_constraintTop_toBottomOf="@id/btnNausea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>